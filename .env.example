# Backend environment (Ubuntu/Dokploy-ready)
NODE_ENV=production
# Dokploy routes public traffic through its proxy. Keep the app listening on an internal port.
PORT=3000

# Public URLs
CLIENT_URL=https://your-frontend-domain.com
BACKEND_PUBLIC_BASE_URL=https://your-backend-domain.com
CORS_ORIGINS=https://your-frontend-domain.com
# Optional: override auto CORS behavior.
# Auto behavior: when CLIENT_URL is not localhost, strict CORS origin checking is disabled.
# DISABLE_CORS_ORIGIN_CHECK=true

# Database
DATABASE_URL=mysql://your_db_user:your_db_password@your-db-host:3306/your_db_name

# Auth
JWT_SECRET=change_this_to_a_long_random_secret
DISABLE_AUTH_CHECK=false
DISABLE_AUTH_RATE_LIMIT=false

# OAuth / Payments
GOOGLE_CLIENT_ID=
STRIPE_SECRET_KEY=

# Contact / branding
COMPANY_ORGANIZATION_NUMBER=

# Email / SMTP
# EMAIL_ADDRESS is the contact and from address (replaces CONTACT_EMAIL)
EMAIL_ADDRESS=no-reply@your-domain.com
EMAIL_COMPANY_NAME=Your Company
EMAIL_COMPANY_ADDRESS=
EMAIL_COMPANY_LOGO_URL=
EMAIL_USE_TEST_RECEIVER=false
EMAIL_TEST_RECEIVER=

EMAIL_HOST=smtp.hostinger.com
EMAIL_PORT=465
EMAIL_SECURE=true
EMAIL_USER=no-reply@your-domain.com
EMAIL_PASS=
EMAIL_FROM_NAME=Your Company

# Shipping / PostNord
POSTNORD_API_KEY=
POSTNORD_CUSTOMER_NUMBER=
POSTNORD_DEBUG_LOGS=false
POSTNORD_USE_PORTAL_PRICING=false
POSTNORD_ENABLE_TRANSIT_TIME=false
POSTNORD_HOST=
POSTNORD_ENV=production
POSTNORD_TRACKING_BASE_URL=https://www.postnord.se/en/our-tools/track-and-trace/?shipmentId=

POSTNORD_SANDBOX_HOST=https://atapi2.postnord.com
POSTNORD_PRODUCTION_HOST=https://atapi2.postnord.com
POSTNORD_DEFAULT_TRACK_PATH=/rest/shipment/v5/trackandtrace/findByIdentifier.json
POSTNORD_DEFAULT_BOOK_EDI_PATH=/rest/shipment/v3/edi
POSTNORD_DEFAULT_LABEL_PDF_PATH=/rest/shipment/v3/edi/labels/pdf
POSTNORD_DEFAULT_LABEL_ZPL_PATH=/rest/shipment/v3/edi/labels/zpl
POSTNORD_DEFAULT_TRANSIT_TIME_PATH=/rest/transport/v1/transittime/calculateRoute
POSTNORD_DEFAULT_COST_PORTAL_PATH=/api/pricing/agreementProduct
POSTNORD_PORTAL_HOST=https://portal.postnord.com
DEFAULT_FALLBACK_CURRENCY=SEK

# Platform pricing defaults
DEFAULT_PLATFORM_COMMISSION_PERCENT=1
DEFAULT_PLATFORM_COMMISSION_FIXED=0
PROMOTION_COMMISSION_PERCENT=5
VAT_SHIPPING_RATE=0.25

# Swish
SWISH_ENABLED=false
SWISH_TEST_MODE=false
SWISH_TEST_HOST=https://mss.cpc.getswish.net
SWISH_PRODUCTION_HOST=https://cpc.getswish.net
SWISH_BASE_HOST=
SWISH_CERTIFICATE_PATH=swish/swish_client_cert
SWISH_CERTIFICATE_PASSWORD=
SWISH_P12_FILENAME=
SWISH_CA_FILENAME=
