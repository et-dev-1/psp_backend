<!doctype html>
<html>
  <head>
    <meta charset="utf-8" />
    <title>Seller Profile Status Update</title>
  </head>
  <body style="margin:0; padding:0; background-color:#f3f4f6; font-family:Arial, Helvetica, sans-serif; color:#111827;">
    <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="background-color:#f3f4f6; padding:24px 12px;">
      <tr>
        <td align="center">
          <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="max-width:680px; background-color:#ffffff; border-radius:16px; overflow:hidden; border:1px solid #e5e7eb;">

            <!-- Header -->
            <tr>
              <td style="padding:28px 32px; background:linear-gradient(135deg, #111827 0%, #374151 100%); color:#ffffff;">
                <table role="presentation" width="100%" cellspacing="0" cellpadding="0">
                  <tr>
                    <td>
                      <table role="presentation" cellspacing="0" cellpadding="0" style="margin-bottom:14px;">
                        <tr>
                          <td style="vertical-align:middle; padding-right:14px;">
                            <table role="presentation" cellspacing="0" cellpadding="0" style="border-collapse:collapse;">
                              <tr>
                                <td style="width:44px;height:44px;border-radius:10px;text-align:center;vertical-align:middle;">{{email_header_logo}}</td>
                              </tr>
                            </table>
                          </td>
                          <td style="vertical-align:middle;">
                            <p style="margin:0; font-size:18px; line-height:24px; font-weight:700; color:#ffffff;">{{company_name}}</p>
                            <p style="margin:4px 0 0 0; font-size:12px; line-height:18px; color:#cbd5e1;">{{company_address}} | Org {{organization_number}}</p>
                          </td>
                        </tr>
                      </table>
                      <h1 style="margin:0; font-size:26px; line-height:32px; font-weight:700;">Seller Profile Update</h1>
                    </td>
                  </tr>
                </table>
              </td>
            </tr>

            <!-- Greeting -->
            <tr>
              <td style="padding:28px 32px 16px 32px;">
                <p style="margin:0 0 8px 0; font-size:16px; color:#111827;">Hi {{seller_name}},</p>
                <p style="margin:0; font-size:14px; line-height:22px; color:#4b5563;">{{intro_text}}</p>
              </td>
            </tr>

            <!-- Status badge -->
            <tr>
              <td style="padding:0 32px 20px 32px;">
                <table role="presentation" cellspacing="0" cellpadding="0">
                  <tr>
                    <td style="background:{{status_bg}}; border-radius:8px; padding:10px 20px;">
                      <p style="margin:0; font-size:13px; font-weight:700; color:{{status_color}}; text-transform:uppercase; letter-spacing:0.8px;">{{status_label}}</p>
                    </td>
                  </tr>
                </table>
              </td>
            </tr>

            <!-- Reason box (only shown when reason exists) -->
            {{reason_block}}

            <!-- Profile details table -->
            <tr>
              <td style="padding:0 32px 24px 32px;">
                <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="border-collapse:separate; border-spacing:0; border:1px solid #e5e7eb; border-radius:12px; overflow:hidden;">
                  <tr style="background:#f9fafb;">
                    <td style="padding:12px 16px; font-size:13px; font-weight:600; color:#374151; width:180px;">Account email</td>
                    <td style="padding:12px 16px; font-size:13px; color:#111827;">{{seller_email}}</td>
                  </tr>
                  <tr>
                    <td style="padding:12px 16px; font-size:13px; font-weight:600; color:#374151;">Profile status</td>
                    <td style="padding:12px 16px; font-size:13px; color:#111827; font-weight:600;">{{status_label}}</td>
                  </tr>
                  <tr style="background:#f9fafb;">
                    <td style="padding:12px 16px; font-size:13px; font-weight:600; color:#374151;">Updated</td>
                    <td style="padding:12px 16px; font-size:13px; color:#111827;">{{updated_at}}</td>
                  </tr>
                </table>
              </td>
            </tr>

            <!-- CTA button -->
            <tr>
              <td style="padding:0 32px 32px 32px;">
                <a href="{{cta_url}}" style="display:inline-block; padding:12px 28px; background:{{cta_bg}}; color:#ffffff; text-decoration:none; border-radius:10px; font-weight:700; font-size:14px;">{{cta_label}}</a>
              </td>
            </tr>

            {{email_footer}}
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
