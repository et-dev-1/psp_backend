<!doctype html>
<html>
  <head>
    <meta charset="utf-8" />
    <title>Your Order Has Been Shipped</title>
  </head>
  <body style="margin:0; padding:0; background-color:#f3f4f6; font-family:Arial, Helvetica, sans-serif; color:#111827;">
    <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="background-color:#f3f4f6; padding:24px 12px;">
      <tr>
        <td align="center">
          <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="max-width:640px; background-color:#ffffff; border-radius:16px; overflow:hidden; border:1px solid #e5e7eb;">

            <!-- Header -->
            <tr>
              <td style="padding:28px 32px; background:linear-gradient(135deg, #1d4ed8 0%, #2563eb 100%); color:#ffffff;">
                <table role="presentation" width="100%" cellspacing="0" cellpadding="0">
                  <tr>
                    <td>
                      <table role="presentation" cellspacing="0" cellpadding="0" style="margin-bottom:14px;">
                        <tr>
                          <td style="vertical-align:middle; padding-right:14px;">
                            <img src="{{company_logo_url}}" alt="{{company_name}} logo" style="display:block; width:48px; height:48px; object-fit:contain; border-radius:10px; background-color:#ffffff; padding:6px;" />
                          </td>
                          <td style="vertical-align:middle;">
                            <p style="margin:0; font-size:17px; font-weight:700; color:#ffffff;">{{company_name}}</p>
                            <p style="margin:3px 0 0; font-size:12px; color:#bfdbfe;">{{company_email}}</p>
                          </td>
                        </tr>
                      </table>
                      <h1 style="margin:0; font-size:26px; font-weight:700; color:#ffffff;">
                        📦 Your Order Has Been Shipped
                      </h1>
                    </td>
                    <td align="right" style="vertical-align:top;">
                      <div style="display:inline-block; padding:10px 14px; border-radius:12px; background-color:rgba(255,255,255,0.15); text-align:left; white-space:nowrap;">
                        <p style="margin:0; font-size:11px; color:#bfdbfe;">Order Date</p>
                        <p style="margin:4px 0 0; font-size:13px; font-weight:600; color:#ffffff;">{{order_date}}</p>
                      </div>
                    </td>
                  </tr>
                </table>
              </td>
            </tr>

            <!-- Greeting -->
            <tr>
              <td style="padding:28px 32px 8px;">
                <p style="margin:0; font-size:16px;">Hello <strong>{{customer_name}}</strong>,</p>
                <p style="margin:10px 0 0; font-size:14px; line-height:22px; color:#4b5563;">
                  Good news! Your order <strong>{{order_id}}</strong> has been shipped and is on its way to you.
                  You can use the tracking information below to follow its progress.
                </p>
              </td>
            </tr>

            <!-- Tracking box -->
            <tr>
              <td style="padding:16px 32px 8px;">
                <div style="border:2px solid #2563eb; border-radius:14px; padding:20px 24px; background-color:#eff6ff;">
                  <p style="margin:0 0 14px; font-size:13px; font-weight:700; color:#1e40af; text-transform:uppercase; letter-spacing:0.5px;">Tracking Information</p>
                  <table role="presentation" width="100%" cellspacing="0" cellpadding="0">
                    <tr>
                      <td style="vertical-align:top; padding-right:16px;">
                        <p style="margin:0 0 4px; font-size:12px; color:#6b7280; font-weight:600; text-transform:uppercase; letter-spacing:0.3px;">Tracking Number</p>
                        <p style="margin:0; font-size:18px; font-weight:700; color:#1d4ed8; letter-spacing:1px; font-family:monospace;">{{tracking_number}}</p>
                      </td>
                      <td align="right" style="vertical-align:middle; white-space:nowrap;">
                        <a href="{{tracking_url}}" target="_blank"
                          style="display:inline-block; padding:10px 20px; background-color:#2563eb; color:#ffffff; font-size:13px; font-weight:700; text-decoration:none; border-radius:8px;">
                          Track Shipment →
                        </a>
                      </td>
                    </tr>
                  </table>
                </div>
              </td>
            </tr>

            <!-- Order summary row -->
            <tr>
              <td style="padding:16px 32px 8px;">
                <table role="presentation" width="100%" cellspacing="0" cellpadding="0">
                  <tr>
                    <td style="width:50%; padding-right:8px; vertical-align:top;">
                      <div style="border:1px solid #e5e7eb; border-radius:12px; padding:16px; background-color:#f9fafb;">
                        <p style="margin:0 0 8px; font-size:12px; font-weight:700; color:#111827; text-transform:uppercase; letter-spacing:0.4px;">Order Details</p>
                        <p style="margin:0 0 6px; font-size:13px;"><strong>Order ID:</strong> {{order_id}}</p>
                        <p style="margin:0; font-size:13px;"><strong>Shipped on:</strong> {{order_date}}</p>
                      </div>
                    </td>
                    <td style="width:50%; padding-left:8px; vertical-align:top;">
                      <div style="border:1px solid #e5e7eb; border-radius:12px; padding:16px; background-color:#f9fafb;">
                        <p style="margin:0 0 8px; font-size:12px; font-weight:700; color:#111827; text-transform:uppercase; letter-spacing:0.4px;">Shipping To</p>
                        <p style="margin:0; font-size:13px; line-height:20px; color:#374151;">{{shipping_address}}</p>
                      </div>
                    </td>
                  </tr>
                </table>
              </td>
            </tr>

            <!-- Footer note -->
            <tr>
              <td style="padding:24px 32px 32px;">
                <div style="border-top:1px solid #e5e7eb; padding-top:18px;">
                  <p style="margin:0 0 8px; font-size:13px; color:#6b7280;">Questions about your order? Contact us:</p>
                  <p style="margin:0 0 4px; font-size:14px; font-weight:700; color:#111827;">{{company_name}}</p>
                  <p style="margin:0 0 4px; font-size:13px; color:#374151;">{{company_email}}</p>
                  <p style="margin:0 0 4px; font-size:13px; color:#374151;">{{company_address}}</p>
                  <p style="margin:0; font-size:12px; color:#9ca3af;">Organization Number: {{organization_number}}</p>
                </div>
              </td>
            </tr>

          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
