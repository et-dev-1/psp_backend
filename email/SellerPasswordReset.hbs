<!doctype html>
<html>
  <head>
    <meta charset="utf-8" />
    <title>Reset Your Password</title>
  </head>
  <body style="margin:0; padding:0; background-color:#f3f4f6; font-family:Arial, Helvetica, sans-serif; color:#111827;">
    <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="background-color:#f3f4f6; padding:24px 12px;">
      <tr>
        <td align="center">
          <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="max-width:760px; background-color:#ffffff; border-radius:16px; overflow:hidden; border:1px solid #e5e7eb;">
            <tr>
              <td style="padding:28px 32px; background:linear-gradient(135deg, #111827 0%, #374151 100%); color:#ffffff;">
                <table role="presentation" width="100%" cellspacing="0" cellpadding="0">
                  <tr>
                    <td>
                      <table role="presentation" cellspacing="0" cellpadding="0" style="margin-bottom:14px;">
                        <tr>
                          <td style="vertical-align:middle; padding-right:14px;">
                            <table role="presentation" cellspacing="0" cellpadding="0" style="border-collapse:collapse;">
                              <tr>
                                <td style="width:44px;height:44px;background:#6d28d9;background:linear-gradient(135deg,#7c3aed,#4f46e5);border-radius:10px;text-align:center;vertical-align:middle;">
                                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#ffffff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg" style="display:block;margin:10px auto;">
                                    <path d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
                                  </svg>
                                </td>
                              </tr>
                            </table>
                          </td>
                          <td style="vertical-align:middle;">
                            <p style="margin:0; font-size:18px; line-height:24px; font-weight:700; color:#ffffff;">{{company_name}}</p>
                          </td>
                        </tr>
                      </table>
                      <h1 style="margin:0; font-size:28px; line-height:34px; font-weight:700;">Reset Your Password</h1>
                    </td>
                  </tr>
                </table>
              </td>
            </tr>

            <tr>
              <td style="padding:28px 32px 8px 32px;">
                <p style="margin:0; font-size:16px;">Hello,</p>
                <p style="margin:10px 0 0 0; font-size:14px; line-height:22px; color:#4b5563;">
                  We received a request to reset the password for your account. Use the link below to set a new password.
                </p>
              </td>
            </tr>

            <tr>
              <td style="padding:20px 32px 8px 32px;">
                <table role="presentation" cellspacing="0" cellpadding="0">
                  <tr>
                    <td>
                      <a href="{{reset_url}}" style="display:inline-block; padding:14px 32px; background-color:#111827; color:#ffffff; text-decoration:none; border-radius:10px; font-size:15px; font-weight:700; letter-spacing:0.3px;">Reset Password</a>
                    </td>
                  </tr>
                </table>
              </td>
            </tr>

            <tr>
              <td style="padding:20px 32px 8px 32px;">
                <div style="border-radius:12px; border:1px solid #fde68a; background-color:#fffbeb; padding:16px;">
                  <p style="margin:0; font-size:13px; line-height:20px; color:#92400e;">
                    <strong>Did not request a password reset?</strong> You can safely ignore this email. Your password will remain unchanged.
                  </p>
                </div>
              </td>
            </tr>

            {{email_footer}}

          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
