<!doctype html>
<html>
  <head>
    <meta charset="utf-8" />
    <title>Commission Update Notice</title>
  </head>
  <body style="margin:0; padding:0; background-color:#f3f4f6; font-family:Arial, Helvetica, sans-serif; color:#111827;">
    <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="background-color:#f3f4f6; padding:24px 12px;">
      <tr>
        <td align="center">
          <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="max-width:760px; background-color:#ffffff; border-radius:16px; overflow:hidden; border:1px solid #e5e7eb;">
            <tr>
              <td style="padding:28px 32px; background:linear-gradient(135deg, #111827 0%, #374151 100%); color:#ffffff;">
                <table role="presentation" width="100%" cellspacing="0" cellpadding="0">
                  <tr>
                    <td>
                      <table role="presentation" cellspacing="0" cellpadding="0" style="margin-bottom:14px;">
                        <tr>
                          <td style="vertical-align:middle; padding-right:14px;">
                            <table role="presentation" cellspacing="0" cellpadding="0" style="border-collapse:collapse;">
                              <tr>
                                <td style="width:44px;height:44px;border-radius:10px;text-align:center;vertical-align:middle;">{{email_header_logo}}</td>
                              </tr>
                            </table>
                          </td>
                          <td style="vertical-align:middle;">
                            <p style="margin:0; font-size:18px; line-height:24px; font-weight:700; color:#ffffff;">{{company_name}}</p>
                            <p style="margin:4px 0 0 0; font-size:12px; line-height:18px; color:#cbd5e1;">{{company_address}} | Org {{organization_number}}</p>
                          </td>
                        </tr>
                      </table>
                      <h1 style="margin:0; font-size:28px; line-height:34px; font-weight:700;">Commission Update Notice</h1>
                    </td>
                  </tr>
                </table>
              </td>
            </tr>

            <tr>
              <td style="padding:28px 32px 8px 32px;">
                <p style="margin:0; font-size:16px;">Hello Seller,</p>
                <p style="margin:10px 0 0 0; font-size:14px; line-height:22px; color:#4b5563;">
                  The platform commission settings were updated by admin. The table below highlights what changed for new orders.
                </p>
              </td>
            </tr>

            <tr>
              <td style="padding:20px 32px 8px 32px;">
                <h2 style="margin:0 0 14px 0; font-size:18px; line-height:24px; color:#111827;">Changed Settings</h2>
                <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="border-collapse:separate; border-spacing:0; border:1px solid #e5e7eb; border-radius:14px; overflow:hidden;">
                  <thead>
                    <tr style="background-color:#111827; color:#ffffff;">
                      <th align="left" style="padding:14px 16px; font-size:13px; font-weight:700;">Setting</th>
                      <th align="left" style="padding:14px 16px; font-size:13px; font-weight:700;">Previous</th>
                      <th align="left" style="padding:14px 16px; font-size:13px; font-weight:700;">Current</th>
                      <th align="left" style="padding:14px 16px; font-size:13px; font-weight:700;">Status</th>
                    </tr>
                  </thead>
                  <tbody>
                    {{change_rows}}
                  </tbody>
                </table>
                <p style="margin:10px 2px 0 2px; font-size:12px; line-height:18px; color:#6b7280;">{{changes_note}}</p>
              </td>
            </tr>

            {{email_footer}}
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
